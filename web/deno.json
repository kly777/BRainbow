{
    "tasks": {
        "dev": "deno run -A npm:@rsbuild/core dev",
        "build": "deno run -A npm:@rsbuild/core build",
        "preview": "deno run -A npm:@rsbuild/core preview",
        "check": "deno check src/**/*.ts src/**/*.tsx",
        "fmt": "deno fmt",
        "lint": "deno lint && deno run -A npm:@biomejs/biome lint --write"
    },
    "imports": {
        "@biomejs/biome": "npm:@biomejs/biome@^2.4.15",
        "solid-js": "npm:solid-js@^1.9.13",
        "solid-js/web": "npm:solid-js@^1.9.13/web",
        "solid-js/store": "npm:solid-js@^1.9.13/store",
        "@solidjs/router": "npm:@solidjs/router@^0.16.1",
        "effect": "npm:effect@^3.21.2",
        "@effect/platform": "npm:@effect/platform@^0.96.1",
        "marked": "npm:marked@^18.0.4",
        "dompurify": "npm:dompurify@^3.4.5",
        "@rsbuild/core": "npm:@rsbuild/core@^2.0.6",
        "@rsbuild/plugin-babel": "npm:@rsbuild/plugin-babel@^1.1.2",
        "@rsbuild/plugin-solid": "npm:@rsbuild/plugin-solid@^1.2.0",
        "@rsbuild/plugin-type-check": "npm:@rsbuild/plugin-type-check@^1.3.4",
        "@types/node": "npm:@types/node@^25.9.1",
        "@/": "./src/"
    },
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "dom.asynciterable", "esnext"],
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "strict": true,
        "skipLibCheck": true
    },
    "nodeModulesDir": "auto",
    "fmt": {
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false
    },
    "lint": {
        "rules": {
            "tags": ["recommended"],
            "exclude": ["require-await", "jsx-no-children-prop"]
        }
    }
}
